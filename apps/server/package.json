{
  "name": "@pb138/server",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/server.ts",
    "./db/validators": "./src/db/validators.ts",
    "./db/schema": "./src/db/schema.ts"
  },
  "scripts": {
    "dev": "bun run --watch --env-file=../../.env src/server.ts",
    "build": "bun build src/server.ts --outdir dist",
    "db:studio": "bun --env-file=../../.env x drizzle-kit studio",
    "db:push": "bun --env-file=../../.env x drizzle-kit push",
    "db:seed": "bun --env-file=../../.env src/db/seed.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/nodemailer": "^8.0.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@elysiajs/bearer": "^1.4.3",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/jwt": "^1.4.1",
    "@elysiajs/openapi": "^1.4.15",
    "drizzle-orm": "^0.45.2",
    "drizzle-typebox": "^0.3.3",
    "elysia": "^1.4.28",
    "nodemailer": "^8.0.5",
    "postgres": "^3.4.9"
  }
}
