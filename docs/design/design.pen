              "fill": "$--muted-foreground",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Senators gathered on the floor of the chamber during the historic infrastructure bill announcement.",
              "lineHeight": 1.5,
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "normal",
              "fontStyle": "italic"
            }
          ]
        },
