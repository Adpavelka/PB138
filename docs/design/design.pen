                  "name": "headline",
                  "fill": "#ffffff",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Senate Unveils Bipartisan Infrastructure Plan Worth $2.3 Trillion",
                  "lineHeight": 1.2,
                  "fontFamily": "Inter",
                  "fontSize": 26,
                  "fontWeight": "800"
                },
                {
                  "type": "frame",
