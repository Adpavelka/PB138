                      "layout": "vertical",
                      "gap": 2,
                      "children": [
                        {
                          "type": "text",
                          "id": "x8soB",
                          "name": "authorName",
                          "fill": "#ffffffe6",
                          "content": "By Sarah Johnson",
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "R16Ec",
                          "name": "dateLine",
                          "fill": "#ffffffaa",
                          "content": "March 22, 2026  ·  8 min read",
                          "fontFamily": "Inter",
