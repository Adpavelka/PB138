# Copy this file to .env and fill in the values
# Never commit .env to git

POSTGRES_USER=newspaper
POSTGRES_PASSWORD=newspaper
POSTGRES_DB=newspaper_db
JWT_SECRET=newspaper

DATABASE_URL=postgres://newspaper:newspaper@localhost:5432/newspaper_db

# SMTP — Mailtrap sandbox (copy credentials from mailtrap.io → Inboxes → SMTP Settings)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your-mailtrap-username
SMTP_PASS=your-mailtrap-password
SMTP_FROM=noreply@example.com

# Base URL of the frontend (used to build links in emails)
FRONTEND_URL=http://localhost:5173
